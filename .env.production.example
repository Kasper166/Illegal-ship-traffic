# ── PROJECT ──────────────────────────────────────────────────────────────────
PROJECT_NAME=darkwater
ENVIRONMENT=production
DEMO_MODE=true
TZ=UTC
LOG_LEVEL=INFO

# ── FASTAPI ───────────────────────────────────────────────────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
BACKEND_CORS_ORIGINS=https://your-app.vercel.app
API_SECRET_KEY=replace_with_long_random_string

# ── POSTGRES (Railway auto-generates DATABASE_URL) ────────────────────────────
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── QDRANT ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=vessel_tracks
QDRANT_URL=http://qdrant:6333
# Optional: set if Qdrant auth is enabled
QDRANT_API_KEY=

# ── CLOUDFLARE R2 ─────────────────────────────────────────────────────────────
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
R2_BUCKET_NAME=darkwater
R2_PUBLIC_URL=

# ── EXTERNAL APIs (optional for live ingestion) ───────────────────────────────
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
CDSE_ODATA_URL=https://catalogue.dataspace.copernicus.eu/odata/v1

GLOBAL_FISHING_WATCH_API_KEY=
GLOBAL_FISHING_WATCH_API_URL=https://gateway.api.globalfishingwatch.org

# ── WANDB (disabled in demo mode) ─────────────────────────────────────────────
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=darkwater

# ── LABEL STUDIO (optional) ───────────────────────────────────────────────────
LABEL_STUDIO_URL=
LABEL_STUDIO_TOKEN=

# ── RUNTIME PATHS ─────────────────────────────────────────────────────────────
DATA_DIR=/app/data
MODELS_DIR=/app/models
