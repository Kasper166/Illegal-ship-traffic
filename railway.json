{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "postgres",
      "source": {
        "type": "image",
        "image": "postgres:16"
      },
      "variables": {
        "POSTGRES_DB": "darkwater",
        "POSTGRES_USER": "darkwater",
        "POSTGRES_PASSWORD": "${{SECRET_POSTGRES_PASSWORD}}"
      }
    },
    {
      "name": "qdrant",
      "source": {
        "type": "image",
        "image": "qdrant/qdrant:latest"
      },
      "deploy": {
        "healthcheckPath": "/healthz",
        "healthcheckTimeout": 30,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": {
        "servicePorts": [
          {
            "internalPort": 6333,
            "protocol": "TCP"
          }
        ]
      }
    },
    {
      "name": "backend",
      "dependsOn": ["postgres", "qdrant"],
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "dashboard/backend/Dockerfile"
      },
      "deploy": {
        "startCommand": "sh -c 'alembic upgrade head && uvicorn dashboard.backend.main:app --host 0.0.0.0 --port 8000'",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 30,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    }
  ]
}
