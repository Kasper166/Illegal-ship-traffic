# Project
PROJECT_NAME=darkwater
ENVIRONMENT=development
TZ=UTC

# FastAPI / Dashboard backend
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_SECRET_KEY=replace_with_long_random_string

# Postgres metadata store
POSTGRES_DB=darkwater
POSTGRES_USER=darkwater
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://darkwater:replace_with_secure_password@postgres:5432/darkwater

# Qdrant vector database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=vessel_tracks
QDRANT_API_KEY=replace_with_qdrant_api_key_if_enabled
QDRANT_URL=http://qdrant:6333

# Label Studio
LABEL_STUDIO_HOST=label-studio
LABEL_STUDIO_PORT=8080
LABEL_STUDIO_URL=http://label-studio:8080
LABEL_STUDIO_USERNAME=admin@darkwater.local
LABEL_STUDIO_PASSWORD=replace_with_secure_password
LABEL_STUDIO_TOKEN=replace_with_label_studio_token

# External APIs / Data providers
COPERNICUS_CLIENT_ID=replace_with_copernicus_client_id
COPERNICUS_CLIENT_SECRET=replace_with_copernicus_client_secret
CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
CDSE_ODATA_URL=https://catalogue.dataspace.copernicus.eu/odata/v1

GLOBAL_FISHING_WATCH_API_KEY=replace_with_gfw_api_key
GLOBAL_FISHING_WATCH_API_URL=https://gateway.api.globalfishingwatch.org

# Experiment tracking / model registry
WANDB_API_KEY=replace_with_wandb_api_key
WANDB_ENTITY=replace_with_wandb_entity
WANDB_PROJECT=darkwater

# YOLO / model training
YOLO_MODEL_BASE=yolov8n.pt
TRAIN_DATA_CONFIG=/app/data/dataset.yaml
TRAIN_EPOCHS=100
TRAIN_BATCH_SIZE=16

# Runtime paths in containers
DATA_DIR=/app/data
MODELS_DIR=/app/models
LOG_LEVEL=INFO
